## 开启接口取数（默认关闭，页面使用 mock 数据）
VITE_USE_API=false

## 后端网关/服务地址（可选；不填则走相对路径 /api/xxx）
VITE_API_BASE_URL=http://127.0.0.1:8080

## Metabase 配置（可选；仅当你用 Metabase 接口取数时需要）
## 直连时填站点根地址（不要带 /api/dataset）
VITE_METABASE_BASE_URL=https://metabase.vrviu.com
## 开发时用 Vite 代理可避免 CORS，与上面二选一
VITE_METABASE_USE_PROXY=false
## TOKEN 会过期导致 401；可同时填下方账号密码，401 时会自动 POST /api/session 换新并重试
VITE_METABASE_SESSION_TOKEN=
VITE_METABASE_USERNAME=
VITE_METABASE_PASSWORD=
VITE_METABASE_AUTOCLOUD_DB_ID=4

## 字节跳动供应 7d（g_instance_id 口径）Metabase database id，默认 131
VITE_METABASE_BYTE_DANCE_SUPPLY_7D_DB_ID=131

## 供应看板全项目 vmid 日 max/avg（dwd_cloudgame_game_vminfo_v2_inc）Metabase database id，默认 131
VITE_METABASE_SUPPLY_VMID_7D_DB_ID=131

## 原力环境 Metabase（供应看板第二个 Tab）
## 原力站点根（不要末尾 /）。仅当 Metabase 已对页面来源配置 CORS 时使用；否则浏览器会 net::ERR_FAILED。
## 开发环境请留空，走 Vite 代理 /api/metabase-yl -> yl-metabase（见 vite.config.js）
# VITE_YUANLI_METABASE_BASE_URL=
VITE_YUANLI_METABASE_SESSION_TOKEN=
VITE_YUANLI_METABASE_USERNAME=
VITE_YUANLI_METABASE_PASSWORD=
## 原力：仅「供应」vminfo_inc 查询用的 Metabase database id（默认 2）；订单走自建 VITE_METABASE_* + METABASE_SUPPLY_ORDERS_DB_ID
VITE_YUANLI_METABASE_DB_ID=2
## 兼容旧配置（未用 VITE_YUANLI_METABASE_DB_ID 时回退）
# VITE_YUANLI_METABASE_SUPPLY_DB_ID=2
# VITE_YUANLI_METABASE_SUPPLY_ORDERS_DB_ID=2

