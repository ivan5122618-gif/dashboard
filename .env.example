# ========== Metabase（浏览器可见 VITE_*，勿把生产密码提交到 git）==========
# 自建 PAAS（走 dev 代理 /api/metabase）
# 若同时配置了 USERNAME+PASSWORD，启动时不会使用 SESSION_TOKEN（避免过期），首次查数前自动登录换新
# VITE_METABASE_USERNAME=
# VITE_METABASE_PASSWORD=
# VITE_METABASE_SESSION_TOKEN=
# 原力 Metabase 上游根地址（无末尾 /；仅 Vite 代理读取，不写 VITE_ 以免进前端包）
# YUANLI_METABASE_ORIGIN=http://yl-metabase.vrviu.com:3000
# 原力站点（走 dev 代理 /api/metabase-yl）
# VITE_YUANLI_METABASE_USERNAME=
# 密码里若含 #、=、... 等，建议双引号：VITE_YUANLI_METABASE_PASSWORD="你的完整密码"
# VITE_YUANLI_METABASE_PASSWORD=
# 原力：同时配置用户名+密码时与自建相同逻辑，不再先用可能过期的 TOKEN
# VITE_YUANLI_METABASE_SESSION_TOKEN=
# 可选：直连原力根地址（不设则用代理）
# VITE_YUANLI_METABASE_BASE_URL=
# 原力 native 查询用的 database id
# VITE_YUANLI_METABASE_DB_ID=

# ========== 企业微信：智能表格 → 结算套餐与项目映射（仅服务端 / Node 读 WECOM_*）==========
# 文档：https://developer.work.weixin.qq.com/document/path/101158
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_DOC_ID=
WECOM_SHEET_ID=
# 列标题须与智能表格一致（key_type 为字段标题时）
# 「结算套餐ID」= 与 Metabase 订单里的结算套餐 id 同一套；「服务平台」= PAAS-YL 的行归入原力映射，其余归入 PAAS
WECOM_FIELD_SETTLEMENT=结算套餐ID
WECOM_FIELD_PROJECT=PAAS映射biz
WECOM_FIELD_PLATFORM=服务平台
# 可选：判定原力行的服务平台取值（大小写不敏感）
WECOM_PLATFORM_YUANLI=PAAS-YL

# 可选：生产构建后浏览器请求映射的完整地址（需自行部署 npm run wecom-proxy 或等价服务）
# VITE_WECOM_SETTLEMENT_MAP_URL=http://127.0.0.1:8787/api/wecom/settlement-map

# 可选：设为 1 时完全不请求企微映射，仅用代码内兜底
# VITE_WECOM_SETTLEMENT_MAP_DISABLED=1

# 调试：控制台标明结算映射来自企微接口还是代码兜底
# VITE_DEBUG_SETTLEMENT_MAP=1
